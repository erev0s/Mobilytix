# Pull-and-run runtime configuration

# Published image tag to pull from GHCR
MOBILYTIX_IMAGE_TAG=latest

# Override only if the images are published under a different namespace
MOBILYTIX_IMAGE_NAMESPACE=ghcr.io/erev0s

# Host folder containing APKs to analyze
MOBILYTIX_APK_INPUT_DIR=/absolute/path/to/apks

# Host folder where Mobilytix persists session state and artifacts.
# Keep this outside the public repository.
MOBILYTIX_WORKSPACE_DIR=/absolute/path/to/mobilytix-workspace

# Local mitmweb password used by the runtime compose file
MOBILYTIX_MITMWEB_TOKEN=mobilytix-local-token
